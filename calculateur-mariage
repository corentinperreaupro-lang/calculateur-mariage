<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Calculateur de tarif – Film de mariage</title>
  <style>
    .tarif-calculator {
      max-width: 500px;
      padding: 16px;
      border: 1px solid #ddd;
      border-radius: 8px;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      margin: 0 auto;
    }
    .tarif-calculator h2, .tarif-calculator h3 {
      margin-bottom: 8px;
    }
    .tarif-calculator label {
      display: block;
      margin-bottom: 8px;
    }
    .tarif-calculator input {
      width: 100%;
      padding: 6px;
      margin-top: 4px;
      box-sizing: border-box;
    }
    .tarif-calculator button {
      margin-top: 12px;
      padding: 10px 14px;
      cursor: pointer;
    }
    .resultat {
      margin-top: 12px;
      background: #f7f7f7;
      padding: 10px;
      border-radius: 6px;
    }
  </style>
</head>
<body>
  <div class="tarif-calculator">
    <h2>Calculateur de tarif – Film de mariage</h2>

    <h3>Tournage</h3>
    <label>Heures de tournage :
      <input type="number" id="heuresTournage" value="10">
    </label>
    <label>Tarif horaire tournage (€) :
      <input type="number" id="tarifTournage" value="90">
    </label>
    <label>Drone (forfait) (€) :
      <input type="number" id="drone" value="200">
    </label>

    <h3>Post‑production</h3>
    <label>Heures de montage :
      <input type="number" id="heuresMontage" value="20">
    </label>
    <label>Tarif horaire montage (€) :
      <input type="number" id="tarifMontage" value="50">
    </label>
    <label>Animation de logo (€) :
      <input type="number" id="animationLogo" value="100">
    </label>

    <h3>Options</h3>
    <label>Teaser 1 min (€) :
      <input type="number" id="teaser" value="150">
    </label>
    <label>Vidéo des discours (€) :
      <input type="number" id="discours" value="0">
    </label>
    <label>Version longue 30 min (€) :
      <input type="number" id="versionLongue" value="0">
    </label>

    <h3>Déplacement</h3>
    <label>Km aller-retour :
      <input type="number" id="km" value="0">
    </label>
    <label>Tarif au km (€) :
      <input type="number" id="tarifKm" value="0.4">
    </label>

    <button id="btnCalcul">Calculer le tarif</button>

    <div class="resultat">
      <p><strong>Tournage :</strong> <span id="totalTournage">0</span> €</p>
      <p><strong>Post‑production :</strong> <span id="totalPostProd">0</span> €</p>
      <p><strong>Options :</strong> <span id="totalOptions">0</span> €</p>
      <p><strong>Déplacement :</strong> <span id="totalDeplacement">0</span> €</p>
      <p><strong>Total :</strong> <span id="totalFinal">0</span> €</p>
    </div>
  </div>

  <script>
    function calculerTarif() {
      const heuresTournage = +document.getElementById('heuresTournage').value || 0;
      const tarifTournage = +document.getElementById('tarifTournage').value || 0;
      const drone = +document.getElementById('drone').value || 0;
      const totalTournage = heuresTournage * tarifTournage + drone;

      const heuresMontage = +document.getElementById('heuresMontage').value || 0;
      const tarifMontage = +document.getElementById('tarifMontage').value || 0;
      const animationLogo = +document.getElementById('animationLogo').value || 0;
      const totalPostProd = heuresMontage * tarifMontage + animationLogo;

      const teaser = +document.getElementById('teaser').value || 0;
      const discours = +document.getElementById('discours').value || 0;
      const versionLongue = +document.getElementById('versionLongue').value || 0;
      const totalOptions = teaser + discours + versionLongue;

      const km = +document.getElementById('km').value || 0;
      const tarifKm = +document.getElementById('tarifKm').value || 0;
      const totalDeplacement = km * tarifKm;

      const totalFinal = totalTournage + totalPostProd + totalOptions + totalDeplacement;

      document.getElementById('totalTournage').textContent = totalTournage.toFixed(0);
      document.getElementById('totalPostProd').textContent = totalPostProd.toFixed(0);
      document.getElementById('totalOptions').textContent = totalOptions.toFixed(0);
      document.getElementById('totalDeplacement').textContent = totalDeplacement.toFixed(0);
      document.getElementById('totalFinal').textContent = totalFinal.toFixed(0);
    }

    document.getElementById('btnCalcul').addEventListener('click', calculerTarif);
  </script>
</body>
</html>
